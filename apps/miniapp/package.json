{
  "name": "piaoxiaozhu-miniapp",
  "version": "1.0.0",
  "private": true,
  "description": "票小助 - 智能票据识别与管理小程序",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "dev:weapp": "taro build --type weapp --watch",
    "build:swan": "taro build --type swan",
    "dev:swan": "taro build --type swan --watch",
    "build:alipay": "taro build --type alipay",
    "dev:alipay": "taro build --type alipay --watch",
    "build:tt": "taro build --type tt",
    "dev:tt": "taro build --type tt --watch",
    "build:h5": "taro build --type h5",
    "dev:h5": "taro build --type h5 --watch"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@tarojs/components": "3.6.36",
    "@tarojs/helper": "3.6.36",
    "@tarojs/plugin-platform-weapp": "3.6.36",
    "@tarojs/plugin-platform-swan": "3.6.36",
    "@tarojs/plugin-platform-alipay": "3.6.36",
    "@tarojs/plugin-platform-tt": "3.6.36",
    "@tarojs/plugin-platform-h5": "3.6.36",
    "@tarojs/react": "3.6.36",
    "@tarojs/runtime": "3.6.36",
    "@tarojs/shared": "3.6.36",
    "@tarojs/taro": "3.6.36",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/runtime": "^7.24.0",
    "@tarojs/cli": "3.6.36",
    "@tarojs/webpack5-runner": "3.6.36",
    "@types/react": "^18.2.0",
    "babel-preset-taro": "3.6.36",
    "sass": "^1.71.0",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0"
  }
}
