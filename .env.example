# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/piaoxiaozhu

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-this-to-a-random-string

# WeChat Mini Program
WX_APPID=your-wechat-appid
WX_SECRET=your-wechat-secret

# WeChat Pay
WX_MCH_ID=your-merchant-id
WX_API_KEY=your-api-key
WX_CERT_PATH=/path/to/cert.pem

# Aliyun OSS
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=piaoxiaozhu

# LLM
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL_NAME=nvidia/nemotron-nano-12b-v2-vl
